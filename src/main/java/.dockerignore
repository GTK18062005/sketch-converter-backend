services:
  - type: web
    name: sketch-converter-backend
    runtime: image
    repo: https://github.com/yourusername/sketch-converter
    plan: free
    dockerfilePath: ./Dockerfile
    envVars:
      - key: PORT
        value: 8080
      - key: RENDER
        value: true
      - key: FRONTEND_URL
        value: https://your-frontend.onrender.com